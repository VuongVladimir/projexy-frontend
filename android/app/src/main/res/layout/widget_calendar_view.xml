<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_calendar_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="8dp"
    android:background="@drawable/widget_container_bg"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/calendar_header_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Calendar"
            android:textColor="#274BFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/calendar_refresh_button"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="@android:color/transparent"
            android:contentDescription="Refresh"
            android:padding="2dp"
            android:src="@android:drawable/ic_popup_sync" />
    </LinearLayout>

    <!-- Content: Calendar (left) | Tasks (right) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:layout_weight="1"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <!-- Left: Calendar -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Month navigation -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/calendar_prev_month"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="Previous"
                    android:scaleType="fitCenter"
                    android:src="@android:drawable/ic_media_previous"
                    android:tint="#0D6EFD" />

                <TextView
                    android:id="@+id/calendar_month_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:textColor="#202020"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/calendar_next_month"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="Next"
                    android:scaleType="fitCenter"
                    android:src="@android:drawable/ic_media_next"
                    android:tint="#0D6EFD" />
            </LinearLayout>

            <!-- Day-of-week headers -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:gravity="center" android:text="S" android:textColor="#94A3B8" android:textSize="10sp" />
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:gravity="center" android:text="M" android:textColor="#94A3B8" android:textSize="10sp" />
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:gravity="center" android:text="T" android:textColor="#94A3B8" android:textSize="10sp" />
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:gravity="center" android:text="W" android:textColor="#94A3B8" android:textSize="10sp" />
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:gravity="center" android:text="T" android:textColor="#94A3B8" android:textSize="10sp" />
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:gravity="center" android:text="F" android:textColor="#94A3B8" android:textSize="10sp" />
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:gravity="center" android:text="S" android:textColor="#EF736B" android:textSize="10sp" />
            </LinearLayout>

            <!-- Week 0 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal" android:baselineAligned="false">
                <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"><TextView android:id="@+id/d0" android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:gravity="center" android:textSize="10sp" /></FrameLayout>
                <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"><TextView android:id="@+id/d1" android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:gravity="center" android:textSize="10sp" /></FrameLayout>
                <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"><TextView android:id="@+id/d2" android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:gravity="center" android:textSize="10sp" /></FrameLayout>
                <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"><TextView android:id="@+id/d3" android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:gravity="center" android:textSize="10sp" /></FrameLayout>
                <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"><TextView android:id="@+id/d4" android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:gravity="center" android:textSize="10sp" /></FrameLayout>
                <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"><TextView android:id="@+id/d5" android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:gravity="center" android:textSize="10sp" /></FrameLayout>
                <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"><TextView android:id="@+id/d6" android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:gravity="center" android:textSize="10sp" /></FrameLayout>
            </LinearLayout>

            <!-- Week 1 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal" android:baselineAligned="false">
                <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"><TextView android:id="@+id/d7" android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:gravity="center" android:textSize="10sp" /></FrameLayout>
                <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"><TextView android:id="@+id/d8" android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:gravity="center" android:textSize="10sp" /></FrameLayout>
                <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"><TextView android:id="@+id/d9" android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:gravity="center" android:textSize="10sp" /></FrameLayout>
                <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"><TextView android:id="@+id/d10" android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:gravity="center" android:textSize="10sp" /></FrameLayout>
                <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"><TextView android:id="@+id/d11" android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:gravity="center" android:textSize="10sp" /></FrameLayout>
                <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"><TextView android:id="@+id/d12" android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:gravity="center" android:textSize="10sp" /></FrameLayout>
                <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"><TextView android:id="@+id/d13" android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:gravity="center" android:textSize="10sp" /></FrameLayout>
            </LinearLayout>

            <!-- Week 2 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal" android:baselineAligned="false">
                <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"><TextView android:id="@+id/d14" android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:gravity="center" android:textSize="10sp" /></FrameLayout>
                <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"><TextView android:id="@+id/d15" android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:gravity="center" android:textSize="10sp" /></FrameLayout>
                <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"><TextView android:id="@+id/d16" android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:gravity="center" android:textSize="10sp" /></FrameLayout>
                <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"><TextView android:id="@+id/d17" android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:gravity="center" android:textSize="10sp" /></FrameLayout>
                <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"><TextView android:id="@+id/d18" android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:gravity="center" android:textSize="10sp" /></FrameLayout>
                <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"><TextView android:id="@+id/d19" android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:gravity="center" android:textSize="10sp" /></FrameLayout>
                <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"><TextView android:id="@+id/d20" android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:gravity="center" android:textSize="10sp" /></FrameLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- Divider -->
        <TextView
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="8dp"
            android:layout_marginRight="8dp"
            android:background="#E2E8F0" />

        <!-- Right: Task list -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/calendar_selected_date_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#202020"
                android:textSize="13sp"
                android:textStyle="bold" />

            <ListView
                android:id="@+id/calendar_tasks_list"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:divider="#F1F5F9"
                android:dividerHeight="1dp"
                android:fadeScrollbars="false"
                android:paddingTop="6dp"
                android:scrollbars="vertical" />

            <TextView
                android:id="@+id/calendar_tasks_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingTop="16dp"
                android:text="No tasks"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
